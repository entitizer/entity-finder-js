{
  "name": "entity-finder",
  "version": "1.0.0",
  "description": "Named entity finder",
  "main": "./lib/index.js",
  "types": "./types/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf ./lib ./types",
    "prebuild": "npm run clean",
    "pretest": "npm run build",
    "test": "ava --no-cache --verbose lib/**/*.test.js",
    "posttest": "rimraf \"./lib/**/*.test.js\" \"./types/**/*.test.d.ts\"",
    "tsc": "tsc",
    "tscw": "tsc -w",
    "preversion": "npm run build",
    "postversion": "git push --follow-tags",
    "prepublishOnly": "npm run build && rimraf \"./lib/**/*.test.js\" \"./types/**/*.test.d.ts\"",
    "find": "node ./run.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "atonic": "^1.0.4",
    "axios": "^1.15.2",
    "debug": "^4.3.4",
    "wikipedia-data": "^0.1.1"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^20.0.0",
    "ava": "^8.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/entitizer/entity-finder-js.git"
  },
  "keywords": [
    "entity",
    "named-entity",
    "finder",
    "entities",
    "ner"
  ],
  "author": "Dumitru Cantea",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/entitizer/entity-finder-js/issues"
  },
  "homepage": "https://github.com/entitizer/entity-finder-js#readme"
}
